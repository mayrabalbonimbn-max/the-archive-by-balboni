# Copie este arquivo para .env.test e preencha com as credenciais do banco de teste.
# Se .env.test não existir, os testes usam o banco de desenvolvimento (DATABASE_URL do .env).
#
# Para criar um banco de teste local:
#   createdb archive_test
#   psql archive_test -c "CREATE EXTENSION IF NOT EXISTS pgcrypto;"

DATABASE_URL=postgres://localhost:5432/archive_test
JWT_SECRET=test_secret_local
